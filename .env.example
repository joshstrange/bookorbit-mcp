# Book Orbit MCP server configuration
#
# Book Orbit issues short-lived (15 min) JWT access tokens and has no long-lived
# API key. The server therefore logs in with your account credentials and
# refreshes / re-logs in automatically as tokens expire.

# Base URL of your Book Orbit instance (with or without a trailing slash).
BOOKORBIT_URL=https://bookorbit.example.com

# Recommended: username + password (enables automatic token refresh).
BOOKORBIT_USERNAME=your-username
BOOKORBIT_PASSWORD=your-password

# Alternative for quick local testing only: a static Bearer token.
# Expires after ~15 minutes and will NOT auto-refresh. Prefer username/password.
# BOOKORBIT_TOKEN=

# Optional: where extracted book text is cached (default: ~/.cache/bookorbit-mcp).
# CACHE_DIR=
